<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Never rewrite Next.js assets or API — prevents ChunkLoadError / SyntaxError
  RewriteRule ^_next/ - [L]
  RewriteRule ^api/ - [L]

  # Browsers request /favicon.ico by default
  RewriteRule ^favicon\.ico$ /favi.png [L]

  # 1. Serve existing files (CSS, JS, images, fonts)
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # 2. Redirect legacy .html URLs to trailing-slash folders
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1/ [R=301,L]

  # 3. Force trailing slash (Next.js trailingSlash: true) — skip static assets
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_URI} !(.*)\.(css|js|mjs|json|png|jpe?g|gif|webp|svg|ico|woff2?|ttf|otf|map)$ [NC]
  RewriteCond %{REQUEST_URI} !(.*)/$
  RewriteRule ^(.*)$ $1/ [L,R=301]

  # 4. Serve index.html inside folders
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteCond %{REQUEST_FILENAME}/index.html -f
  RewriteRule ^(.*)/$ $1/index.html [L]

  # 5. Handle 404
  ErrorDocument 404 /404/index.html
</IfModule>

<IfModule mod_headers.c>
  # Fresh HTML after each deploy — avoids stale chunk references
  <FilesMatch "\.(html)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Long cache for hashed build assets
  <FilesMatch "\.(css|js|woff2?|ttf|otf|png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
</IfModule>
